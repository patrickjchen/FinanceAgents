# Force Python files
*.py linguist-language=Python

# Mark HTML as documentation (exclude from stats)
*.html linguist-documentation

# Ignore generated files (optional)
docs/* linguist-documentation
dist/* linguist-generated
build/* linguist-generated

# Treat SEC/raw filings as generated data, not source language
raw_data/*.htm linguist-generated=true
raw_data/*.html linguist-generated=true

# Ignore vector DB artifacts in language statistics
**/vector_db/** linguist-generated=true

# Force Python files to Python
*.py linguist-language=Python
